{
  "name": "CONTROL PLANE - GitHub commit Data Table dedupe scheduled v4",
  "nodes": [
    {
      "parameters": {},
      "id": "manual-trigger-redacted-v4",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        120,
        220
      ]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 1
            }
          ]
        }
      },
      "id": "schedule-trigger-redacted-v4",
      "name": "Schedule Trigger - controlled polling",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        120,
        420
      ]
    },
    {
      "parameters": {
        "url": "https://api.github.com/repos/mrhz1973/control-plane/commits?per_page=1",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            },
            {
              "name": "User-Agent",
              "value": "control-plane-n8n-datatable-dedupe-scheduled-test"
            }
          ]
        },
        "options": {}
      },
      "id": "github-fetch-latest-commit-redacted-v4",
      "name": "GitHub - Fetch latest control-plane commit",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        400,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const commit = Array.isArray($json) ? $json[0] : $json;\nconst sha = commit?.sha || '';\nconst message = commit?.commit?.message || 'no commit message';\nconst url = commit?.html_url || 'no URL';\nreturn [{ json: { stateKey: 'github:mrhz1973/control-plane:last_commit_sha', currentSha: sha, shortSha: sha.substring(0, 7), message, url, sourceRepo: 'mrhz1973/control-plane' } }];"
      },
      "id": "prepare-latest-event-redacted-v4",
      "name": "Prepare latest commit event",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        320
      ]
    },
    {
      "parameters": {
        "resource": "row",
        "operation": "get",
        "dataTableId": {
          "__rl": true,
          "mode": "name",
          "value": "control_plane_state"
        },
        "matchType": "allConditions",
        "filters": {
          "conditions": [
            {
              "keyName": "key",
              "condition": "eq",
              "keyValue": "github:mrhz1973/control-plane:last_commit_sha"
            }
          ]
        },
        "returnAll": false,
        "limit": 1
      },
      "id": "datatable-get-state-redacted-v4",
      "name": "Data Table - Get last seen commit",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [
        960,
        320
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const latest = $('Prepare latest commit event').first().json;\nconst storedValue = $json.value || '';\nconst isNew = Boolean(latest.currentSha && latest.currentSha !== storedValue);\nreturn [{ json: { ...latest, previousSha: storedValue || '', isNew } }];"
      },
      "id": "decide-dedupe-redacted-v4",
      "name": "Decide Data Table dedupe",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1240,
        320
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "is-new-commit-condition-redacted-v4",
              "leftValue": "={{ $json.isNew }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-new-commit-redacted-v4",
      "name": "IF - New commit?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1520,
        320
      ]
    },
    {
      "parameters": {
        "resource": "row",
        "operation": "upsert",
        "dataTableId": {
          "__rl": true,
          "mode": "name",
          "value": "control_plane_state"
        },
        "matchType": "allConditions",
        "filters": {
          "conditions": [
            {
              "keyName": "key",
              "condition": "eq",
              "keyValue": "github:mrhz1973/control-plane:last_commit_sha"
            }
          ]
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "key": "github:mrhz1973/control-plane:last_commit_sha",
            "value": "={{ $json.currentSha }}",
            "updated_at": "={{ $now.toISO() }}",
            "note": "Latest notified commit SHA for scheduled control-plane GitHub poll"
          },
          "schema": [
            {
              "id": "key",
              "displayName": "key",
              "required": false,
              "defaultMatch": false,
              "display": true,
              "type": "string",
              "canBeUsedToMatch": true
            },
            {
              "id": "value",
              "displayName": "value",
              "required": false,
              "defaultMatch": false,
              "display": true,
              "type": "string",
              "canBeUsedToMatch": true
            },
            {
              "id": "updated_at",
              "displayName": "updated_at",
              "required": false,
              "defaultMatch": false,
              "display": true,
              "type": "string",
              "canBeUsedToMatch": false
            },
            {
              "id": "note",
              "displayName": "note",
              "required": false,
              "defaultMatch": false,
              "display": true,
              "type": "string",
              "canBeUsedToMatch": false
            }
          ]
        }
      },
      "id": "datatable-upsert-state-redacted-v4",
      "name": "Data Table - Upsert last seen commit",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [
        1800,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "const latest = $('Decide Data Table dedupe').first().json;\nconst previous = latest.previousSha ? latest.previousSha.substring(0, 7) : 'none';\nreturn [{ json: { text: `CONTROL PLANE scheduled poll commit notification\\nRepo: ${latest.sourceRepo}\\nNew commit: ${latest.shortSha}\\nPrevious: ${previous}\\nMessage: ${latest.message}\\nURL: ${latest.url}` } }];"
      },
      "id": "format-datatable-telegram-message-redacted-v4",
      "name": "Format Data Table Telegram message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
        220
      ]
    },
    {
      "parameters": {
        "chatId": "__CONFIGURE_CHAT_ID_IN_N8N_UI__",
        "text": "={{ $json.text }}",
        "additionalFields": {}
      },
      "id": "telegram-send-datatable-dedupe-redacted-v4",
      "name": "Telegram - Send Data Table deduped message",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        2360,
        220
      ],
      "credentials": {
        "telegramApi": {
          "id": "__REDACTED_N8N_CREDENTIAL_ID__",
          "name": "CONTROL PLANE - Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { status: 'duplicate_skip', reason: 'Latest commit already stored in control_plane_state', currentSha: $json.currentSha, previousSha: $json.previousSha } }];"
      },
      "id": "duplicate-skip-redacted-v4",
      "name": "Duplicate skip - no Telegram",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1800,
        420
      ]
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [
        [
          {
            "node": "GitHub - Fetch latest control-plane commit",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Schedule Trigger - controlled polling": {
      "main": [
        [
          {
            "node": "GitHub - Fetch latest control-plane commit",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "GitHub - Fetch latest control-plane commit": {
      "main": [
        [
          {
            "node": "Prepare latest commit event",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Prepare latest commit event": {
      "main": [
        [
          {
            "node": "Data Table - Get last seen commit",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Data Table - Get last seen commit": {
      "main": [
        [
          {
            "node": "Decide Data Table dedupe",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Decide Data Table dedupe": {
      "main": [
        [
          {
            "node": "IF - New commit?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF - New commit?": {
      "main": [
        [
          {
            "node": "Data Table - Upsert last seen commit",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Duplicate skip - no Telegram",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Data Table - Upsert last seen commit": {
      "main": [
        [
          {
            "node": "Format Data Table Telegram message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Format Data Table Telegram message": {
      "main": [
        [
          {
            "node": "Telegram - Send Data Table deduped message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "pinData": {},
  "versionId": "__REDACTED_VERSION_ID__",
  "triggerCount": 0,
  "tags": [
    {
      "name": "control-plane"
    },
    {
      "name": "github"
    },
    {
      "name": "telegram"
    },
    {
      "name": "datatable"
    },
    {
      "name": "dedupe"
    },
    {
      "name": "schedule-capable"
    },
    {
      "name": "redacted"
    },
    {
      "name": "v4"
    }
  ],
  "meta": {
    "redaction": "No token, no operational chat_id, no credential id, no workflow id, no webhook secret are committed.",
    "runtimeStatus": "Template/export record only. Not imported or executed by this commit. Workflow active=false. Schedule Trigger is present but will not run until the imported workflow is explicitly activated in n8n.",
    "stateStore": "Uses n8n Data Table named control_plane_state with columns key, value, updated_at, note.",
    "source": "Manual Trigger or Schedule Trigger fetches latest public commit from mrhz1973/control-plane via GitHub REST API. No GitHub token required for this public read test.",
    "dedupe": "Reads the state row by key. Sends Telegram only when latest SHA differs from stored value, then upserts the new SHA.",
    "polling": "Scheduled polling interval is 1 minute in this redacted template. It does not satisfy a strict 30-second push-notification SLA; webhook remains a separate future gate for sub-30-second delivery.",
    "nextGate": "Import this v4 workflow in n8n, configure Data Table selection if needed, configure Telegram chatId locally in the UI, save it inactive, then perform a manual test. Do not activate schedule until manual validation passes."
  }
}
