      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const j=$json;\nconst localPlanPath='/home/node/.n8n-files/gate-d-plan.md';\nconst attachedFileName='gate-d-plan.md';\nconst lines=[\n'CONTROL PLANE plan_detected',\n`Repo: ${j.repo}`,\n`Plan: ${j.planPath}`,\n`Commit: ${j.shortSha}`,\n`Status: ${j.fileStatus}`,\n`Changes: +${j.additions ?? '?'} / -${j.deletions ?? '?'}`,\n'',\n`Message: ${j.latestCommitMessage || ''}`,\n`URL: https://github.com/${j.repo}/blob/${j.commitSha}/${j.planPath}`,\n''\n'Gate D LIVE. Review the plan in GitHub before execution.',\n'Plan file attachment follows on parallel branch.'\n];\nreturn {json:{text:lines.join('\\n'),event:j.event,planPath:j.planPath,repo:j.repo,commitSha:j.commitSha,shortSha:j.shortSha,localPlanPath,attachedFileName,rawPlanUrl:`https://raw.githubusercontent.com/${j.repo}/${j.commitSha}/${j.planPath}`}};"
