    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const target=$('Emit watched repos (3)').item.json;const resp=$input.item.json;const commit=Array.isArray(resp)?resp[0]:resp;const sha=commit?.sha||'';const message=String(commit?.commit?.message||'no commit message').split('\\n')[0];return {json:{stateKey:target.stateKey,currentSha:sha,shortSha:sha?sha.substring(0,7):'',message,url:commit?.html_url||'',sourceRepo:target.sourceRepo,ownerRepo:target.ownerRepo}};"
      },
