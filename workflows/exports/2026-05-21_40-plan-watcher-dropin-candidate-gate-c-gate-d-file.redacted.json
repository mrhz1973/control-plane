    {
      "parameters": {
        "jsCode": "const commit=$input.first().json;const gate=$('Code - Plan watcher repo gate stub').first().json;const files=Array.isArray(commit.files)?commit.files:[];const planFiles=files.filter(f=>/^docs\\/plans\\/[^/]+\\.plan\\.md$/.test(String(f.filename||'')));if(!planFiles.length){return [{json:{event:'no_plan_detected',repo:gate.repo,commitSha:gate.currentSha,shortSha:gate.shortSha,changedFileCount:files.length,changedFiles:files.map(f=>f.filename).slice(0,30),gate:'C+D-dropin-candidate'}}];}return planFiles.map(f=>({json:{event:'plan_detected',repo:gate.repo,commitSha:gate.currentSha,shortSha:gate.shortSha,latestCommitUrl:gate.latestCommitUrl,latestCommitMessage:gate.latestCommitMessage,planPath:f.filename,fileStatus:f.status||'',additions:f.additions??null,deletions:f.deletions??null,changes:f.changes??null,gate:'C+D-dropin-candidate'}}));"
      },
